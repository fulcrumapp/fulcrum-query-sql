{
  "name": "@fulcrumapp/query-sql",
  "version": "2.0.1",
  "description": "Fulcrum Query SQL Utilities",
  "homepage": "http://github.com/fulcrumapp/fulcrum-query-sql",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "prepublishOnly": "yarn run clean && yarn run build",
    "lint": "eslint src/* src/**/*",
    "build": "tsdown && tsc --emitDeclarationOnly --noEmit false",
    "clean": "rm -rf dist",
    "typecheck": "tsc -b"
  },
  "author": "Fulcrum",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "git://github.com/fulcrumapp/fulcrum-query-sql.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "@fulcrumapp/fulcrum-core": "^1.5.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.3.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "jest": "^30.0.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@fulcrumapp/pg-query-deparser": "0.0.4",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.1"
  },
  "keywords": [
    "fulcrum"
  ],
  "peerDependencies": {
    "@fulcrumapp/fulcrum-core": "^1.5.3",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.1"
  }
}
